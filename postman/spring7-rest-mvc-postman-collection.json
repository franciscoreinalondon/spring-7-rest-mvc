  "item": [
    {
      "name": "Info",
      "item": [
        {
          "name": "README",
          "request": {
            "method": "GET",
            "description": "Orden recomendado:\\n1. Auth / Get access token\\n2. Categories / Search y rellena categoryId si no se guarda autom\u00e1ticamente\\n3. Customers / Create\\n4. Milks / Create y Milks / Create second milk\\n5. Milk Orders / Create\\n6. Probar add/update/remove line\\n\\nSi alg\u00fan endpoint no coincide exactamente con tu proyecto, ajusta la URL en Postman. La colecci\u00f3n asume rutas kebab-case bajo /api/v1."
          },
          "response": []
        }
      ]
